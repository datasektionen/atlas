{% extends "base.html.j2" %}

{% block full_title %}Atlas{% endblock full_title %}

{% block heading %}{{ ctx.t("index.heading") }}{% endblock heading %}

{% block content %}
<h1>
    {% if let Some(user) = ctx.user %}
    {{ ctx.t1("index.heading.inner.user", user.display_name()) }}
    {% else %}
    {{ ctx.t("index.heading.inner") }}
    {% endif %}
</h1>

<p>{{ ctx.t("index.description")|safe }}</p>
{% endblock content %}

{% block full_footer %}
{% include "default_footer.html.j2" %}
{% endblock full_footer %}
