<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://aurora.datasektionen.se" />
    <link rel="icon" type="image/svg+xml" href="/static/favicon.svg" />
    <script type="text/javascript">
        window.methone_conf = {
            system_name: "atlas",
            color_scheme: "pink",
            {% if let Some(user) = ctx.user %}
            login_text: "{{ user.display_name() }}",
            login_href: "/",
            {% else %}
            login_text: "Logga in",
            login_href: "/auth/login",
            {% endif %}
            links: [
                //{
                //    str: "Text",
                //    href: "/"
                //},
            ]
         }
    </script>
    <script async src="https://methone.datasektionen.se/bar.js"></script>
</head>
<body>
    <div id="methone-container-replace"></div>
    <div id="application">
        <p>Hello, world!</p>
        {% if let Some(user) = ctx.user %}
        <p>Permissions for {{ user.username() }}:</p>
        <ul>
            {% for (id, scope) in user.permissions() %}
            <li>
                {{ id }}
                {% if let Some(scope) = scope %}
                :{{ scope }}
                {% endif %}
            </li>
            {% endfor %}
        </ul>
        {% endif %}
    </div>
</body>
</html>
