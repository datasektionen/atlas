{% macro field_validation(form, name) -%}
{%- if form.field_errors(name).next().is_some() -%}
aria-invalid="true"
{%- else if form.field_value(name).is_some() -%}
aria-invalid="false"
{%- endif -%}
{%- endmacro field_validation %}

{% macro field_with_default(form, name, default) -%}
name="{{ name }}"
{%- let value = form.field_value(name) -%}
value='{{ value.unwrap_or(default) }}'
{%- call field_validation(form, name) -%}{%- endcall -%}
{%- endmacro field_with_default %}

{% macro field(form, name) -%}
{%- call field_with_default(form, name, "") -%}{%- endcall -%}
{%- endmacro field %}

{% macro checkbox_with_default(form, name, default) -%}
type="checkbox"
name="{{ name }}"
{%- if form.field_value(name).is_some() || default -%}
checked{{ ' ' }}
{%- endif -%}
{%- if form.field_errors(name).next().is_some() -%}
aria-invalid="true"
{%- else if form.errors().next().is_some() -%}
aria-invalid="false"
{%- endif -%}
{%- endmacro checkbox_with_default %}

{% macro checkbox(form, name) -%}
{%- call checkbox_with_default(form, name, false) -%}{%- endcall -%}
{%- endmacro checkbox %}

{% macro option(value, selected_value) -%}
value="{{ value }}"
{%- if value == selected_value -%}
selected
{%- endif -%}
{%- endmacro option %}

{% macro option_form_with_default(form, name, value, default) -%}
value="{{ value }}"
{%- if form.field_value(name).unwrap_or(default) == value -%}
selected
{%- endif -%}
{%- endmacro option_form_with_default %}

{% macro option_form(form, name, value) -%}
{%- call option_form_with_default(form, name, value, "") -%}{%- endcall -%}
{%- endmacro option_form %}
